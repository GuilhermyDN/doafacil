generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoInstituicao {
  Refeicao
  Banho
  Cobertor
}

enum NivelDoador {
  nice
  cool
  tough
  ruler
  fstar
  topnotch
  goat
  killer
}

enum TipoMissao {
  PRIMEIRA_DOACAO
  FAMILIA
  META_REFEICAO
  MES_COMPLETO
  META_VALOR
  INDICACAO
  CUSTOM
}

enum RoleAdmin {
  SUPER_ADMIN
  ADMIN
}

model Instituicao {
  id                Int             @id @default(autoincrement())
  nome              String
  tipo              TipoInstituicao
  valor             Float
  cor               String
  bg                String
  emoji             String
  pixKey            String
  ativo             Boolean         @default(true)
  mercadoPagoToken  String?
  mpPublicKey       String?
  mpConnectToken    String?         @unique
  mpSetupToken      String?         @unique
  gastosToken       String?         @unique
  mpAccountId       String?

  doacoes   Doacao[]
  gastos    Gasto[]
  qrEventos QREvento[]
}

model Doacao {
  id            Int       @id @default(autoincrement())
  doadorNome    String
  doadorEmail   String?
  doadorTel     String?
  doadorId      Int?
  tagId         Int?
  instituicaoId Int
  eventoId      Int?
  quantidade    Int
  valorTotal    Float
  pago             Boolean   @default(false)
  cancelado        Boolean   @default(false)
  metodoPagamento  String?   // "pix" | "cartao"
  dataCriacao      DateTime  @default(now())
  dataPagamento    DateTime?
  observacao       String?
  mpPaymentId      String?

  doador      Doador?     @relation(fields: [doadorId], references: [id])
  tag         Tag?        @relation(fields: [tagId], references: [id])
  instituicao Instituicao @relation(fields: [instituicaoId], references: [id])
  evento      Evento?     @relation(fields: [eventoId], references: [id])
}

model Doador {
  id             Int         @id @default(autoincrement())
  numero         String      @unique
  nome           String
  apelido        String?
  // Email NÃO é unique: cada tag gera um Doador próprio, então a mesma
  // pessoa pode aparecer em múltiplos registros (um por serial). A
  // identidade do doador no sistema é o serial da tag, não o email.
  email          String?
  telefone       String?
  avatar         String
  totalDoado     Float       @default(0)
  pontos         Int         @default(0)
  nivel          NivelDoador @default(nice)
  badge          String?
  homenagem      String?
  missaoCompleta Boolean     @default(false)
  isVoluntario   Boolean     @default(false)
  servicoVoluntario String?
  createdAt      DateTime    @default(now())

  doacoes Doacao[]
  missoes MissaoDoador[]
  tags    Tag[]
}

model Tag {
  id          Int       @id @default(autoincrement())
  serial      String    @unique  // GS-HB25-D01-0247-59KJ
  ano         Int                // 25
  campanha    String             // D01
  sequencia   Int                // 247
  chave       String             // 59KJ
  doadorId    Int?
  vinculadaEm DateTime?
  createdAt   DateTime  @default(now())

  doador  Doador?  @relation(fields: [doadorId], references: [id])
  doacoes Doacao[]
  scans   TagScan[]
}

model TagScan {
  id          Int      @id @default(autoincrement())
  tagId       Int
  ip          String?
  userAgent   String?
  ehDono      Boolean  @default(false)
  createdAt   DateTime @default(now())

  tag Tag @relation(fields: [tagId], references: [id])
}

model Missao {
  id              Int        @id @default(autoincrement())
  titulo          String
  descricao       String
  pontos          Int
  emoji           String
  ativa           Boolean    @default(true)
  tipo            TipoMissao
  destaque        Boolean    @default(false)
  periodoDestaque String?    // "semana" | "mes" | null
  inicioDestaque  DateTime?
  fimDestaque     DateTime?

  doadores MissaoDoador[]
}

model MissaoDoador {
  id         Int       @id @default(autoincrement())
  doadorId   Int
  missaoId   Int
  completa   Boolean   @default(false)
  completaEm DateTime?

  doador Doador @relation(fields: [doadorId], references: [id])
  missao Missao @relation(fields: [missaoId], references: [id])

  @@unique([doadorId, missaoId])
}

model Evento {
  id         Int      @id @default(autoincrement())
  nome       String
  dataEvento DateTime
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())

  doacoes   Doacao[]
  qrEventos QREvento[]
}

model QREvento {
  id            Int    @id @default(autoincrement())
  eventoId      Int
  instituicaoId Int
  urlDoacao     String
  qrCodeBase64  String @db.Text
  valor         Float

  evento      Evento      @relation(fields: [eventoId], references: [id])
  instituicao Instituicao @relation(fields: [instituicaoId], references: [id])
}

model Gasto {
  id            Int      @id @default(autoincrement())
  instituicaoId Int
  desc          String
  valor         Float
  data          DateTime
  comprovante   Boolean  @default(false)
  arquivoUrl    String?

  instituicao Instituicao @relation(fields: [instituicaoId], references: [id])
}

model PedidoPatch {
  id           Int      @id @default(autoincrement())
  doadorId     Int?
  doadorNome   String
  doadorEmail  String
  doadorTel    String?
  nivel        String
  preco        Float
  endereco     String
  cidade       String
  cep          String
  status       String   @default("pendente") // pendente | produzindo | enviado | entregue
  observacoes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminUser {
  id    Int       @id @default(autoincrement())
  email String    @unique
  senha String
  nome  String
  role  RoleAdmin @default(ADMIN)
}

model SiteConfig {
  id                    Int      @id @default(1)
  nomeOrganizacao       String   @default("Humanity Bearers")
  emailContato          String   @default("")
  whatsapp              String   @default("")
  mpAccessToken         String   @default("")
  mpPublicKey           String   @default("")
  pixChaveAdmin         String   @default("")
  campanhaAtual         String   @default("D01")
  campanhaAno           Int      @default(25)
  updatedAt             DateTime @updatedAt
}
